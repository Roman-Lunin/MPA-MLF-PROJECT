        "plt.plot(fold_numbers, fold_acc_scores, marker=\"o\", label=\"Validation Accuracy\")\n",
        "plt.plot(fold_numbers, fold_scores, marker=\"o\", label=\"Macro F1\")\n",
        "plt.title(\"Cross-validation results\")\n",
        "plt.xlabel(\"Fold\")\n",
        "plt.ylabel(\"Score\")\n",
