        "# =========================================================\n",
        "# BLOCK 8 - Build image maps\n",
        "# =========================================================\n",
        "\n",
        "# funkce vytvori mapu: cislo obrazku -> cesta k obrazku\n",
        "def build_image_map(file_list):\n",
        "    image_map = {}\n",
        "\n",
        "    for path in file_list:\n",
        "        file_name = os.path.basename(path)\n",
        "\n",
        "        if file_name.startswith(\"img_\") and file_name.endswith(\".png\"):\n",
        "            num_str = file_name.replace(\"img_\", \"\").replace(\".png\", \"\")\n",
        "\n",
        "            if num_str.isdigit():\n",
        "                image_map[int(num_str)] = path\n",
        "\n",
        "    return image_map\n",
        "\n",
        "\n",
        "train_image_map = build_image_map(train_pngs)\n",
        "test_image_map = build_image_map(test_pngs)\n",
        "\n",
        "print(\"Namapovane trenovaci obrazky:\", len(train_image_map))\n",
        "print(\"Namapovane testovaci obrazky:\", len(test_image_map))\n",
        "\n",
        "\n",
        "# dulezite: obrazky jsou cislovane od 1, ale ID v CSV od 0\n",
        "# proto pouzivame file_num = id + 1\n",
        "def get_train_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "\n",
        "    if file_num not in train_image_map:\n",
        "        raise FileNotFoundError(f\"Trenovaci obrazek img_{file_num}.png nebyl nalezen\")\n",
        "\n",
        "    return train_image_map[file_num]\n",
        "\n",
        "\n",
        "def get_test_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "\n",
        "    if file_num not in test_image_map:\n",
        "        raise FileNotFoundError(f\"Testovaci obrazek img_{file_num}.png nebyl nalezen\")\n",
        "\n",
        "    return test_image_map[file_num]\n",
