        "# =========================================================\n",
        "# BLOCK 5 - Extract dataset\n",
        "# =========================================================\n",
        "\n",
        "# funkce rozbali zip soubor pouze v pripade, ze obrazky jeste nejsou rozbalene\n",
        "def unzip_if_needed(zip_path, extract_to):\n",
        "    if not os.path.exists(zip_path):\n",
        "        raise FileNotFoundError(f\"Soubor nebyl nalezen: {zip_path}\")\n",
        "\n",
        "    png_count = 0\n",
        "\n",
        "    for root, _, files in os.walk(extract_to):\n",
        "        for file_name in files:\n",
        "            if file_name.lower().endswith(\".png\"):\n",
        "                png_count += 1\n",
        "\n",
        "    if png_count > 0:\n",
        "        print(f\"Soubory uz jsou rozbalene ve slozce {extract_to}: {png_count}\")\n",
        "        return\n",
        "\n",
        "    print(f\"Rozbaluji {zip_path} do {extract_to} ...\")\n",
        "\n",
        "    with zipfile.ZipFile(zip_path, \"r\") as zip_file:\n",
        "        zip_file.extractall(extract_to)\n",
        "\n",
        "    print(\"Hotovo.\")\n",
        "\n",
        "\n",
        "unzip_if_needed(TRAIN_ZIP, TRAIN_DIR)\n",
        "unzip_if_needed(TEST_ZIP, TEST_DIR)\n",
        "\n"
      ],
