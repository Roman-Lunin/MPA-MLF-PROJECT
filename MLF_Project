        "test_df = submission_example[[\"id\", \"image_path\"]].copy()\n",
        "\n",
        "test_dataset = OccupancyDataset(\n",
        "    test_df,\n",
        "    transform=valid_transform,\n",
        "    is_test=True\n",
        ")\n",
        "\n",
        "test_loader = DataLoader(\n",
        "    test_dataset,\n",
        "    batch_size=CFG[\"batch_size\"],\n",
        "    shuffle=False,\n",
        "    num_workers=CFG[\"num_workers\"],\n",
        "    pin_memory=True,\n",
        "    persistent_workers=True if CFG[\"num_workers\"] > 0 else False\n",
        ")\n",
        "\n",
        "\n",
        "def predict_with_model(model, loader):\n",
        "    model.eval()\n",
        "\n",
        "    probs_all = []\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for images, _ in loader:\n",
        "            images = images.to(device, non_blocking=True)\n",
        "            images = images.contiguous(memory_format=torch.channels_last)\n",
        "\n",
        "            if CFG[\"use_amp\"] and torch.cuda.is_available():\n",
        "                with torch.cuda.amp.autocast():\n",
        "                    outputs = model(images)\n",
        "\n",
        "            else:\n",
        "                outputs = model(images)\n",
        "\n",
        "            probs = torch.softmax(outputs, dim=1)\n",
        "            probs_all.append(probs.cpu().numpy())\n",
        "\n",
        "    return np.concatenate(probs_all, axis=0)\n",
        "\n",
        "\n",
        "def predict_with_tta(model, dataframe, num_tta=3):\n",
        "    tta_probs = []\n",
        "\n",
        "    print(\"Base prediction\")\n",
        "\n",
        "    base_dataset = OccupancyDataset(\n",
        "        dataframe,\n",
        "        transform=valid_transform,\n",
        "        is_test=True\n",
        "    )\n",
        "\n",
        "    base_loader = DataLoader(\n",
        "        base_dataset,\n",
        "        batch_size=CFG[\"batch_size\"],\n",
        "        shuffle=False,\n",
        "        num_workers=CFG[\"num_workers\"],\n",
        "        pin_memory=True,\n",
        "        persistent_workers=True if CFG[\"num_workers\"] > 0 else False\n",
        "    )\n",
        "\n",
        "    base_probs = predict_with_model(model, base_loader)\n",
        "    tta_probs.append(base_probs)\n",
        "\n",
        "    del base_dataset, base_loader\n",
        "\n",
        "    gc.collect()\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "    for t in range(num_tta):\n",
        "        print(f\"TTA round {t + 1}/{num_tta}\")\n",
        "\n",
        "        tta_dataset = OccupancyDataset(\n",
        "            dataframe,\n",
        "            transform=tta_transform,\n",
        "            is_test=True\n",
        "        )\n",
        "\n",
        "        tta_loader = DataLoader(\n",
        "            tta_dataset,\n",
        "            batch_size=CFG[\"batch_size\"],\n",
        "            shuffle=False,\n",
        "            num_workers=CFG[\"num_workers\"],\n",
        "            pin_memory=True,\n",
        "            persistent_workers=True if CFG[\"num_workers\"] > 0 else False\n",
        "        )\n",
        "\n",
        "        probs = predict_with_model(model, tta_loader)\n",
        "        tta_probs.append(probs)\n",
        "\n",
        "        del tta_dataset, tta_loader\n",
        "\n",
        "        gc.collect()\n",
        "        torch.cuda.empty_cache()\n",
        "\n",
        "    return np.mean(tta_probs, axis=0)\n"
