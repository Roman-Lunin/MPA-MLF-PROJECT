      "source": [
        "# =========================================================\n",
        "# MPA-MLF Final Project\n",
        "# Room Occupancy Classification\n",
        "# EfficientNet-B1 + 5-fold CV + top-2 checkpoints + TTA\n",
        "# Notebook version - structured similarly to university labs\n",
        "# =========================================================\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 1 - Install libraries\n",
        "# =========================================================\n",
        "\n",
        "!pip install -q timm\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 2 - Import libraries\n",
        "# =========================================================\n",
        "\n",
        "import os\n",
        "import gc\n",
        "import time\n",
        "import zipfile\n",
        "import random\n",
        "import warnings\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from PIL import Image\n",
        "\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "from sklearn.model_selection import StratifiedKFold\n",
        "from sklearn.metrics import accuracy_score, f1_score, confusion_matrix, classification_report\n",
        "\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from torchvision import transforms\n",
        "\n",
        "import timm\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 3 - Basic settings\n",
        "# =========================================================\n",
        "\n",
        "# funkce pro nastaveni seedu kvuli opakovatelnosti vysledku\n",
        "def set_seed(seed=42):\n",
        "    random.seed(seed)\n",
        "    np.random.seed(seed)\n",
        "    torch.manual_seed(seed)\n",
        "    torch.cuda.manual_seed_all(seed)\n",
        "\n",
        "\n",
        "set_seed(42)\n",
        "\n",
        "torch.backends.cudnn.benchmark = True\n",
        "\n",
        "# nastaveni zarizeni pro trenovani\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "print(\"Pouzite zarizeni:\", device)\n",
        "\n",
        "if torch.cuda.is_available():\n",
        "    print(\"GPU:\", torch.cuda.get_device_name(0))\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 4 - File paths\n",
        "# =========================================================\n",
        "\n",
        "# cesty k souborum v Google Colab\n",
        "TRAIN_ZIP = \"/content/x_train.zip\"\n",
        "TEST_ZIP = \"/content/x_test.zip\"\n",
        "TRAIN_CSV = \"/content/y_train_v2.csv\"\n",
        "SUBMISSION_EXAMPLE_CSV = \"/content/y_test_submission_example_v2.csv\"\n",
        "\n",
        "TRAIN_DIR = \"/content/x_train\"\n",
        "TEST_DIR = \"/content/x_test\"\n",
        "MODEL_DIR = \"/content/models_v23\"\n",
        "\n",
        "os.makedirs(TRAIN_DIR, exist_ok=True)\n",
        "os.makedirs(TEST_DIR, exist_ok=True)\n",
        "os.makedirs(MODEL_DIR, exist_ok=True)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 5 - Extract dataset\n",
        "# =========================================================\n",
        "\n",
        "# funkce rozbali zip soubor pouze v pripade, ze obrazky jeste nejsou rozbalene\n",
        "def unzip_if_needed(zip_path, extract_to):\n",
        "    if not os.path.exists(zip_path):\n",
        "        raise FileNotFoundError(f\"Soubor nebyl nalezen: {zip_path}\")\n",
        "\n",
        "    png_count = 0\n",
        "\n",
        "    for root, _, files in os.walk(extract_to):\n",
        "        for file_name in files:\n",
        "            if file_name.lower().endswith(\".png\"):\n",
        "                png_count += 1\n",
        "\n",
        "    if png_count > 0:\n",
        "        print(f\"Soubory uz jsou rozbalene ve slozce {extract_to}: {png_count}\")\n",
        "        return\n",
        "\n",
        "    print(f\"Rozbaluji {zip_path} do {extract_to} ...\")\n",
        "\n",
        "    with zipfile.ZipFile(zip_path, \"r\") as zip_file:\n",
        "        zip_file.extractall(extract_to)\n",
        "\n",
        "    print(\"Hotovo.\")\n",
        "\n",
        "\n",
        "unzip_if_needed(TRAIN_ZIP, TRAIN_DIR)\n",
        "unzip_if_needed(TEST_ZIP, TEST_DIR)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 6 - Load image paths and CSV files\n",
        "# =========================================================\n",
        "\n",
        "# funkce nacte vsechny PNG obrazky ze slozky\n",
        "def collect_pngs(folder):\n",
        "    pngs = []\n",
        "\n",
        "    for root, _, files in os.walk(folder):\n",
        "        for file_name in files:\n",
        "            if file_name.lower().endswith(\".png\"):\n",
        "                pngs.append(os.path.join(root, file_name))\n",
        "\n",
        "    return sorted(pngs)\n",
        "\n",
        "\n",
        "train_pngs = collect_pngs(TRAIN_DIR)\n",
        "test_pngs = collect_pngs(TEST_DIR)\n",
        "\n",
        "print(\"Pocet trenovacich obrazku:\", len(train_pngs))\n",
        "print(\"Pocet testovacich obrazku:\", len(test_pngs))\n",
        "\n",
        "# nacteni tabulek s labely a ukazkovou submission\n",
        "df = pd.read_csv(TRAIN_CSV)\n",
        "submission_example = pd.read_csv(SUBMISSION_EXAMPLE_CSV)\n",
        "\n",
        "print(\"\\nPrvnich 5 radku trenovaci tabulky:\")\n",
        "display(df.head())\n",
        "\n",
        "print(\"Tvar trenovaci tabulky:\", df.shape)\n",
        "print(\"Tvar submission example tabulky:\", submission_example.shape)\n",
        "\n",
        "print(\"\\nRozlozeni trid:\")\n",
        "display(df[\"target\"].value_counts().sort_index())\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 7 - Plot class distribution\n",
        "# =========================================================\n",
        "\n",
        "class_distribution = df[\"target\"].value_counts().sort_index()\n",
        "\n",
        "plt.figure(figsize=(7, 4))\n",
        "plt.bar(class_distribution.index, class_distribution.values)\n",
        "plt.title(\"Class distribution in training dataset\")\n",
        "plt.xlabel(\"Class\")\n",
        "plt.ylabel(\"Count\")\n",
        "plt.xticks(class_distribution.index)\n",
        "plt.grid(axis=\"y\", alpha=0.3)\n",
        "plt.show()\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 8 - Build image maps\n",
        "# =========================================================\n",
        "\n",
        "# funkce vytvori mapu: cislo obrazku -> cesta k obrazku\n",
        "def build_image_map(file_list):\n",
        "    image_map = {}\n",
        "\n",
        "    for path in file_list:\n",
        "        file_name = os.path.basename(path)\n",
        "\n",
        "        if file_name.startswith(\"img_\") and file_name.endswith(\".png\"):\n",
        "            num_str = file_name.replace(\"img_\", \"\").replace(\".png\", \"\")\n",
        "\n",
        "            if num_str.isdigit():\n",
        "                image_map[int(num_str)] = path\n",
        "\n",
        "    return image_map\n",
        "\n",
        "\n",
        "train_image_map = build_image_map(train_pngs)\n",
        "test_image_map = build_image_map(test_pngs)\n",
        "\n",
        "print(\"Namapovane trenovaci obrazky:\", len(train_image_map))\n",
        "print(\"Namapovane testovaci obrazky:\", len(test_image_map))\n",
        "\n",
        "\n",
        "# dulezite: obrazky jsou cislovane od 1, ale ID v CSV od 0\n",
        "# proto pouzivame file_num = id + 1\n",
        "def get_train_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "\n",
        "    if file_num not in train_image_map:\n",
        "        raise FileNotFoundError(f\"Trenovaci obrazek img_{file_num}.png nebyl nalezen\")\n",
        "\n",
        "    return train_image_map[file_num]\n",
        "\n",
        "\n",
        "def get_test_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "\n",
        "    if file_num not in test_image_map:\n",
        "        raise FileNotFoundError(f\"Testovaci obrazek img_{file_num}.png nebyl nalezen\")\n",
        "\n",
        "    return test_image_map[file_num]\n",
        "\n",
        "\n",
        "df[\"image_path\"] = df[\"id\"].apply(get_train_img_path_from_id)\n",
        "submission_example[\"image_path\"] = submission_example[\"id\"].apply(get_test_img_path_from_id)\n",
        "\n",
        "print(\"\\nKontrola trenovacich cest:\")\n",
        "display(df[[\"id\", \"target\", \"image_path\"]].head())\n",
        "\n",
        "print(\"\\nKontrola testovacich cest:\")\n",
        "display(submission_example[[\"id\", \"image_path\"]].head())\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 9 - Show sample images\n",
        "# =========================================================\n",
        "\n",
        "# ukazka nekolika obrazku z datasetu\n",
        "def show_sample_images(dataframe, n=8):\n",
        "    sample_df = dataframe.sample(n=n, random_state=42).reset_index(drop=True)\n",
        "\n",
        "    plt.figure(figsize=(14, 6))\n",
        "\n",
        "    for i in range(n):\n",
        "        image = Image.open(sample_df.loc[i, \"image_path\"]).convert(\"RGB\")\n",
        "\n",
        "        plt.subplot(2, 4, i + 1)\n",
        "        plt.imshow(image)\n",
        "        plt.title(f\"ID: {sample_df.loc[i, 'id']} | Class: {sample_df.loc[i, 'target']}\")\n",
        "        plt.axis(\"off\")\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "show_sample_images(df, n=8)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 10 - Configuration\n",
        "# =========================================================\n",
        "\n",
        "CFG = {\n",
        "    \"img_size\": 256,\n",
        "    \"batch_size\": 32,\n",
        "    \"epochs\": 14,\n",
        "    \"lr\": 6e-4,\n",
        "    \"weight_decay\": 1e-4,\n",
        "    \"num_folds\": 5,\n",
        "    \"num_classes\": 4,\n",
        "    \"model_name\": \"efficientnet_b1\",\n",
        "    \"patience\": 5,\n",
        "    \"num_workers\": 2,\n",
        "    \"use_amp\": True,\n",
        "    \"label_smoothing\": 0.03,\n",
        "    \"tta\": True,\n",
        "    \"tta_rounds\": 3,\n",
        "    \"top_k_checkpoints\": 2,\n",
        "}\n",
        "\n",
        "CFG\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 11 - Image transformations\n",
        "# =========================================================\n",
        "\n",
        "# transformace pro trenovaci data\n",
        "train_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "\n",
        "    transforms.RandomAffine(\n",
        "        degrees=0,\n",
        "        translate=(0.035, 0.035),\n",
        "        scale=(0.97, 1.03),\n",
        "        shear=None\n",
        "    ),\n",
        "\n",
        "    transforms.ColorJitter(\n",
        "        brightness=0.04,\n",
        "        contrast=0.06,\n",
        "        saturation=0.02,\n",
        "        hue=0.005\n",
        "    ),\n",
        "\n",
        "    transforms.ToTensor(),\n",
        "\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "\n",
        "# transformace pro validacni data\n",
        "valid_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "\n",
        "    transforms.ToTensor(),\n",
        "\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "\n",
        "# jemne transformace pro test-time augmentation\n",
        "tta_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "\n",
        "    transforms.RandomAffine(\n",
        "        degrees=0,\n",
        "        translate=(0.02, 0.02),\n",
        "        scale=(0.99, 1.01)\n",
        "    ),\n",
        "\n",
        "    transforms.ToTensor(),\n",
        "\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 12 - Dataset class\n",
        "# =========================================================\n",
        "\n",
        "class OccupancyDataset(Dataset):\n",
        "    def __init__(self, dataframe, transform=None, is_test=False):\n",
        "        self.dataframe = dataframe.reset_index(drop=True).copy()\n",
        "        self.transform = transform\n",
        "        self.is_test = is_test\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.dataframe)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        row = self.dataframe.iloc[idx]\n",
        "        img_path = row[\"image_path\"]\n",
        "\n",
        "        image = Image.open(img_path).convert(\"RGB\")\n",
        "\n",
        "        if self.transform is not None:\n",
        "            image = self.transform(image)\n",
        "\n",
        "        if self.is_test:\n",
        "            return image, int(row[\"id\"])\n",
        "\n",
        "        label = int(row[\"target\"])\n",
        "\n",
        "        return image, label\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 13 - Model definition\n",
        "# =========================================================\n",
        "\n",
        "class OccupancyModel(nn.Module):\n",
        "    def __init__(self, model_name=\"efficientnet_b1\", num_classes=4, pretrained=True):\n",
        "        super().__init__()\n",
        "\n",
        "        self.model = timm.create_model(\n",
        "            model_name,\n",
        "            pretrained=pretrained,\n",
        "            num_classes=num_classes\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        return self.model(x)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 14 - Class weights\n",
        "# =========================================================\n",
        "\n",
        "# vahy trid pomahaji pri pripadne nevyvazenosti datasetu\n",
        "class_counts = df[\"target\"].value_counts().sort_index().values.astype(np.float32)\n",
        "\n",
        "class_weights = 1.0 / class_counts\n",
        "class_weights = class_weights / class_weights.sum() * len(class_weights)\n",
        "class_weights = torch.tensor(class_weights, dtype=torch.float32).to(device)\n",
        "\n",
        "print(\"Pocet vzorku ve tridach:\", class_counts)\n",
        "print(\"Vahy trid:\", class_weights)\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 15 - Plot helper functions\n",
        "# =========================================================\n",
        "\n",
        "def plot_training_curves(train_acc_history, val_acc_history, train_loss_history, val_loss_history, fold):\n",
        "    epochs_range = range(1, len(train_acc_history) + 1)\n",
        "\n",
        "    plt.figure(figsize=(14, 5))\n",
        "\n",
        "    plt.subplot(1, 2, 1)\n",
        "    plt.plot(epochs_range, train_acc_history, label=\"Train Accuracy\")\n",
        "    plt.plot(epochs_range, val_acc_history, label=\"Validation Accuracy\")\n",
        "    plt.title(f\"Model Accuracy - Fold {fold}\")\n",
        "    plt.xlabel(\"Epoch\")\n",
        "    plt.ylabel(\"Accuracy\")\n",
        "    plt.grid(alpha=0.3)\n",
        "    plt.legend()\n",
        "\n",
        "    plt.subplot(1, 2, 2)\n",
        "    plt.plot(epochs_range, train_loss_history, label=\"Train Loss\")\n",
        "    plt.plot(epochs_range, val_loss_history, label=\"Validation Loss\")\n",
        "    plt.title(f\"Model Loss - Fold {fold}\")\n",
        "    plt.xlabel(\"Epoch\")\n",
        "    plt.ylabel(\"Loss\")\n",
        "    plt.grid(alpha=0.3)\n",
        "    plt.legend()\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "def plot_confusion_matrix(cm, fold):\n",
        "    plt.figure(figsize=(6, 5))\n",
        "    plt.imshow(cm, interpolation=\"nearest\", cmap=\"Blues\")\n",
        "    plt.title(f\"Confusion Matrix - Validation Set - Fold {fold}\")\n",
        "    plt.colorbar()\n",
        "\n",
        "    classes = list(range(CFG[\"num_classes\"]))\n",
        "    tick_marks = np.arange(len(classes))\n",
        "\n",
        "    plt.xticks(tick_marks, classes)\n",
        "    plt.yticks(tick_marks, classes)\n",
        "\n",
        "    threshold = cm.max() / 2.0\n",
        "\n",
        "    for i in range(cm.shape[0]):\n",
        "        for j in range(cm.shape[1]):\n",
        "            color = \"white\" if cm[i, j] > threshold else \"black\"\n",
        "\n",
        "            plt.text(\n",
        "                j,\n",
        "                i,\n",
        "                format(cm[i, j], \"d\"),\n",
        "                horizontalalignment=\"center\",\n",
        "                color=color,\n",
        "                fontsize=12,\n",
        "                fontweight=\"bold\"\n",
        "            )\n",
        "\n",
        "    plt.ylabel(\"True label\")\n",
        "    plt.xlabel(\"Predicted label\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 16 - Train and validation functions\n",
        "# =========================================================\n",
        "\n",
        "def train_one_epoch(model, loader, criterion, optimizer, scaler=None):\n",
        "    model.train()\n",
        "\n",
        "    running_loss = 0.0\n",
        "    preds_all = []\n",
        "    targets_all = []\n",
        "\n",
        "    for images, targets in loader:\n",
        "        images = images.to(device, non_blocking=True)\n",
        "        images = images.contiguous(memory_format=torch.channels_last)\n",
        "\n",
        "        targets = targets.to(device, non_blocking=True)\n",
        "\n",
        "        optimizer.zero_grad(set_to_none=True)\n",
        "\n",
        "        if CFG[\"use_amp\"] and torch.cuda.is_available():\n",
        "            with torch.cuda.amp.autocast():\n",
        "                outputs = model(images)\n",
        "                loss = criterion(outputs, targets)\n",
        "\n",
        "            scaler.scale(loss).backward()\n",
        "            scaler.step(optimizer)\n",
        "            scaler.update()\n",
        "\n",
        "        else:\n",
        "            outputs = model(images)\n",
        "            loss = criterion(outputs, targets)\n",
        "\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "        running_loss += loss.item() * images.size(0)\n",
        "\n",
        "        preds = torch.argmax(outputs, dim=1)\n",
        "\n",
        "        preds_all.extend(preds.detach().cpu().numpy())\n",
        "        targets_all.extend(targets.detach().cpu().numpy())\n",
        "\n",
        "    epoch_loss = running_loss / len(loader.dataset)\n",
        "    epoch_acc = accuracy_score(targets_all, preds_all)\n",
        "    epoch_f1 = f1_score(targets_all, preds_all, average=\"macro\")\n",
        "\n",
        "    return epoch_loss, epoch_acc, epoch_f1\n",
        "\n",
        "\n",
        "def valid_one_epoch(model, loader, criterion):\n",
        "    model.eval()\n",
        "\n",
        "    running_loss = 0.0\n",
        "    preds_all = []\n",
        "    targets_all = []\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for images, targets in loader:\n",
        "            images = images.to(device, non_blocking=True)\n",
        "            images = images.contiguous(memory_format=torch.channels_last)\n",
        "\n",
        "            targets = targets.to(device, non_blocking=True)\n",
        "\n",
        "            if CFG[\"use_amp\"] and torch.cuda.is_available():\n",
        "                with torch.cuda.amp.autocast():\n",
        "                    outputs = model(images)\n",
        "                    loss = criterion(outputs, targets)\n",
        "\n",
        "            else:\n",
        "                outputs = model(images)\n",
        "                loss = criterion(outputs, targets)\n",
        "\n",
        "            running_loss += loss.item() * images.size(0)\n",
        "\n",
        "            preds = torch.argmax(outputs, dim=1)\n",
        "\n",
        "            preds_all.extend(preds.detach().cpu().numpy())\n",
        "            targets_all.extend(targets.detach().cpu().numpy())\n",
        "\n",
        "    epoch_loss = running_loss / len(loader.dataset)\n",
        "    epoch_acc = accuracy_score(targets_all, preds_all)\n",
        "    epoch_f1 = f1_score(targets_all, preds_all, average=\"macro\")\n",
        "\n",
        "    cm = confusion_matrix(\n",
        "        targets_all,\n",
        "        preds_all,\n",
        "        labels=list(range(CFG[\"num_classes\"]))\n",
        "    )\n",
        "\n",
        "    return epoch_loss, epoch_acc, epoch_f1, cm, targets_all, preds_all\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 17 - Checkpoint helper\n",
        "# =========================================================\n",
        "\n",
        "def update_top_checkpoints(top_list, score, path, max_k):\n",
        "    top_list.append((score, path))\n",
        "    top_list = sorted(top_list, key=lambda x: x[0], reverse=True)\n",
        "\n",
        "    while len(top_list) > max_k:\n",
        "        removed_score, removed_path = top_list.pop(-1)\n",
        "\n",
        "        if os.path.exists(removed_path):\n",
        "            os.remove(removed_path)\n",
        "\n",
        "    return top_list\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 18 - Cross-validation training\n",
        "# =========================================================\n",
        "\n",
        "skf = StratifiedKFold(\n",
        "    n_splits=CFG[\"num_folds\"],\n",
        "    shuffle=True,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "fold_scores = []\n",
        "fold_acc_scores = []\n",
        "all_checkpoint_paths = []\n",
        "\n",
        "for fold, (train_idx, valid_idx) in enumerate(skf.split(df, df[\"target\"])):\n",
        "    print(\"\\n\" + \"=\" * 70)\n",
        "    print(f\"FOLD {fold + 1}/{CFG['num_folds']}\")\n",
        "    print(\"=\" * 70)\n",
        "\n",
        "    train_df = df.iloc[train_idx].reset_index(drop=True)\n",
        "    valid_df = df.iloc[valid_idx].reset_index(drop=True)\n",
        "\n",
        "    train_dataset = OccupancyDataset(\n",
        "        train_df,\n",
        "        transform=train_transform,\n",
        "        is_test=False\n",
        "    )\n",
        "\n",
        "    valid_dataset = OccupancyDataset(\n",
        "        valid_df,\n",
        "        transform=valid_transform,\n",
        "        is_test=False\n",
        "    )\n",
        "\n",
        "    train_loader = DataLoader(\n",
        "        train_dataset,\n",
        "        batch_size=CFG[\"batch_size\"],\n",
        "        shuffle=True,\n",
        "        num_workers=CFG[\"num_workers\"],\n",
        "        pin_memory=True,\n",
        "        persistent_workers=True if CFG[\"num_workers\"] > 0 else False\n",
        "    )\n",
        "\n",
        "    valid_loader = DataLoader(\n",
        "        valid_dataset,\n",
        "        batch_size=CFG[\"batch_size\"],\n",
        "        shuffle=False,\n",
        "        num_workers=CFG[\"num_workers\"],\n",
        "        pin_memory=True,\n",
        "        persistent_workers=True if CFG[\"num_workers\"] > 0 else False\n",
        "    )\n",
        "\n",
        "    model = OccupancyModel(\n",
        "        model_name=CFG[\"model_name\"],\n",
        "        num_classes=CFG[\"num_classes\"],\n",
        "        pretrained=True\n",
        "    ).to(device)\n",
        "\n",
        "    model = model.to(memory_format=torch.channels_last)\n",
        "\n",
        "    criterion = nn.CrossEntropyLoss(\n",
        "        weight=class_weights,\n",
        "        label_smoothing=CFG[\"label_smoothing\"]\n",
        "    )\n",
        "\n",
        "    optimizer = optim.AdamW(\n",
        "        model.parameters(),\n",
        "        lr=CFG[\"lr\"],\n",
        "        weight_decay=CFG[\"weight_decay\"]\n",
        "    )\n",
        "\n",
        "    scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
        "        optimizer,\n",
        "        T_max=CFG[\"epochs\"],\n",
        "        eta_min=1e-6\n",
        "    )\n",
        "\n",
        "    scaler = torch.cuda.amp.GradScaler(\n",
        "        enabled=CFG[\"use_amp\"] and torch.cuda.is_available()\n",
        "    )\n",
        "\n",
        "    best_score = -1.0\n",
        "    best_f1 = -1.0\n",
        "    best_acc = -1.0\n",
        "\n",
        "    patience_counter = 0\n",
        "    best_cm = None\n",
        "    best_report = None\n",
        "\n",
        "    top_checkpoints = []\n",
        "\n",
        "    train_acc_history = []\n",
        "    val_acc_history = []\n",
        "    train_loss_history = []\n",
        "    val_loss_history = []\n",
        "\n",
        "    for epoch in range(CFG[\"epochs\"]):\n",
        "        start_time = time.time()\n",
        "\n",
        "        train_loss, train_acc, train_f1 = train_one_epoch(\n",
        "            model,\n",
        "            train_loader,\n",
        "            criterion,\n",
        "            optimizer,\n",
        "            scaler\n",
        "        )\n",
        "\n",
        "        valid_loss, valid_acc, valid_f1, cm, y_true, y_pred = valid_one_epoch(\n",
        "            model,\n",
        "            valid_loader,\n",
        "            criterion\n",
        "        )\n",
        "\n",
        "        scheduler.step()\n",
        "        epoch_time = time.time() - start_time\n",
        "\n",
        "        train_acc_history.append(train_acc)\n",
        "        val_acc_history.append(valid_acc)\n",
        "        train_loss_history.append(train_loss)\n",
        "        val_loss_history.append(valid_loss)\n",
        "\n",
        "        score = 0.85 * valid_acc + 0.15 * valid_f1\n",
        "\n",
        "        print(\n",
        "            f\"Epoch {epoch + 1:02d}/{CFG['epochs']} | \"\n",
        "            f\"train_loss={train_loss:.4f} | \"\n",
        "            f\"train_acc={train_acc:.4f} | \"\n",
        "            f\"train_f1={train_f1:.4f} | \"\n",
        "            f\"valid_loss={valid_loss:.4f} | \"\n",
        "            f\"valid_acc={valid_acc:.4f} | \"\n",
        "            f\"valid_f1={valid_f1:.4f} | \"\n",
        "            f\"score={score:.4f} | \"\n",
        "            f\"time={epoch_time:.1f}s\"\n",
        "        )\n",
        "\n",
        "        ckpt_path = os.path.join(\n",
        "            MODEL_DIR,\n",
        "            f\"fold_{fold}_epoch_{epoch + 1}_score_{score:.6f}.pth\"\n",
        "        )\n",
        "\n",
        "        if len(top_checkpoints) < CFG[\"top_k_checkpoints\"] or score > min(x[0] for x in top_checkpoints):\n",
        "            torch.save(model.state_dict(), ckpt_path)\n",
        "\n",
        "            top_checkpoints = update_top_checkpoints(\n",
        "                top_checkpoints,\n",
        "                score,\n",
        "                ckpt_path,\n",
        "                CFG[\"top_k_checkpoints\"]\n",
        "            )\n",
        "\n",
        "            print(\"Saved checkpoint:\", ckpt_path)\n",
        "\n",
        "        if score > best_score:\n",
        "            best_score = score\n",
        "            best_f1 = valid_f1\n",
        "            best_acc = valid_acc\n",
        "            patience_counter = 0\n",
        "            best_cm = cm\n",
        "            best_report = classification_report(y_true, y_pred, digits=4)\n",
        "\n",
        "        else:\n",
        "            patience_counter += 1\n",
        "\n",
        "        if patience_counter >= CFG[\"patience\"]:\n",
        "            print(\"Early stopping.\")\n",
        "            break\n",
        "\n",
        "    print(\"\\nBest accuracy for fold:\", round(best_acc, 6))\n",
        "    print(\"Best macro F1 for fold:\", round(best_f1, 6))\n",
        "    print(\"Best combined score:\", round(best_score, 6))\n",
        "\n",
        "    print(\"\\nBest confusion matrix:\")\n",
        "    print(best_cm)\n",
        "\n",
        "    print(\"\\nBest classification report:\")\n",
        "    print(best_report)\n",
        "\n",
        "    plot_training_curves(\n",
        "        train_acc_history,\n",
        "        val_acc_history,\n",
        "        train_loss_history,\n",
        "        val_loss_history,\n",
        "        fold + 1\n",
        "    )\n",
        "\n",
        "    plot_confusion_matrix(best_cm, fold + 1)\n",
        "\n",
        "    top_checkpoints = sorted(top_checkpoints, key=lambda x: x[0], reverse=True)\n",
        "    fold_paths = [path for _, path in top_checkpoints]\n",
        "\n",
        "    print(\"\\nTop checkpoints for this fold:\")\n",
        "\n",
        "    for score_value, path in top_checkpoints:\n",
        "        print(round(score_value, 6), path)\n",
        "\n",
        "    all_checkpoint_paths.extend(fold_paths)\n",
        "\n",
        "    fold_scores.append(best_f1)\n",
        "    fold_acc_scores.append(best_acc)\n",
        "\n",
        "    del model, train_loader, valid_loader, train_dataset, valid_dataset\n",
        "\n",
        "    gc.collect()\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "\n",
        "# =========================================================\n",
        "# BLOCK 19 - Cross-validation results\n",
        "# =========================================================\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"CV RESULTS\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "print(\"Fold accuracy scores:\", [round(x, 6) for x in fold_acc_scores])\n",
        "print(\"Fold macro F1 scores:\", [round(x, 6) for x in fold_scores])\n",
        "\n",
        "print(\"Mean CV accuracy:\", round(np.mean(fold_acc_scores), 6))\n",
        "print(\"Mean CV macro F1:\", round(np.mean(fold_scores), 6))\n",
        "\n",
        "print(\"Std CV accuracy:\", round(np.std(fold_acc_scores), 6))\n",
        "print(\"Std CV macro F1:\", round(np.std(fold_scores), 6))\n",
        "\n",
        "print(\"Max Fold Accuracy:\", round(np.max(fold_acc_scores), 6))\n",
        "print(\"Max Fold Macro F1:\", round(np.max(fold_scores), 6))\n",
        "\n",
        "print(\"\\nFINAL BEST RESULTS\")\n",
        "print(\"Best validation accuracy:\", round(np.max(fold_acc_scores), 6))\n",
        "print(\"Mean validation accuracy:\", round(np.mean(fold_acc_scores), 6))\n",
        "print(\"Best validation macro F1:\", round(np.max(fold_scores), 6))\n",
        "print(\"Mean validation macro F1:\", round(np.mean(fold_scores), 6))\n",
        "\n",
        "print(\"\\nTotal checkpoints used for final ensemble:\", len(all_checkpoint_paths))\n",
        "\n",
        "\n",
        "# =========================================================\n",
