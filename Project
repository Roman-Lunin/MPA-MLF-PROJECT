        "# =========================\n",
        "# 5. Unzip data\n",
        "# =========================\n",
        "def unzip_if_needed(zip_path, extract_to):\n",
        "    if not os.path.exists(zip_path):\n",
        "        raise FileNotFoundError(f\"File not found: {zip_path}\")\n",
        "\n",
        "    png_count = 0\n",
        "    for root, _, files in os.walk(extract_to):\n",
        "        for f in files:\n",
        "            if f.lower().endswith(\".png\"):\n",
        "                png_count += 1\n",
        "\n",
        "    if png_count > 0:\n",
        "        print(f\"Files already extracted in {extract_to}: {png_count}\")\n",
        "        return\n",
        "\n",
        "    print(f\"Extracting {zip_path} to {extract_to} ...\")\n",
        "    with zipfile.ZipFile(zip_path, \"r\") as z:\n",
        "        z.extractall(extract_to)\n",
        "    print(\"Done.\")\n",
        "\n",
        "unzip_if_needed(TRAIN_ZIP, TRAIN_DIR)\n",
        "unzip_if_needed(TEST_ZIP, TEST_DIR)\n",
        "\n",
        "# =========================\n",
        "# 6. Collect PNG files\n",
        "# =========================\n",
        "def collect_pngs(folder):\n",
        "    pngs = []\n",
        "    for root, _, files in os.walk(folder):\n",
        "        for f in files:\n",
        "            if f.lower().endswith(\".png\"):\n",
        "                pngs.append(os.path.join(root, f))\n",
        "    return sorted(pngs)\n",
        "\n",
        "train_pngs = collect_pngs(TRAIN_DIR)\n",
        "test_pngs = collect_pngs(TEST_DIR)\n",
        "\n",
        "print(\"Train PNG count:\", len(train_pngs))\n",
        "print(\"Test PNG count:\", len(test_pngs))\n",
        "\n",
        "# =========================\n",
        "# 7. Load CSV\n",
        "# =========================\n",
        "df = pd.read_csv(TRAIN_CSV)\n",
        "submission_example = pd.read_csv(SUBMISSION_EXAMPLE_CSV)\n",
        "\n",
        "print(\"\\nTrain CSV head:\")\n",
        "print(df.head())\n",
        "\n",
        "print(\"\\nTrain CSV shape:\", df.shape)\n",
        "print(\"Submission example shape:\", submission_example.shape)\n",
        "\n",
        "print(\"\\nClass distribution:\")\n",
        "print(df[\"target\"].value_counts().sort_index())\n",
        "\n",
        "# =========================\n",
        "# 8. Build image maps\n",
        "# =========================\n",
        "def build_image_map(file_list):\n",
        "    image_map = {}\n",
        "    for path in file_list:\n",
        "        name = os.path.basename(path)\n",
        "        if name.startswith(\"img_\") and name.endswith(\".png\"):\n",
        "            num_str = name.replace(\"img_\", \"\").replace(\".png\", \"\")\n",
        "            if num_str.isdigit():\n",
        "                image_map[int(num_str)] = path\n",
        "    return image_map\n",
        "\n",
        "train_image_map = build_image_map(train_pngs)\n",
        "test_image_map = build_image_map(test_pngs)\n",
        "\n",
        "print(\"\\nMapped train images:\", len(train_image_map))\n",
        "print(\"Mapped test images:\", len(test_image_map))\n",
        "\n",
        "def get_train_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "    if file_num not in train_image_map:\n",
        "        raise FileNotFoundError(f\"Train image img_{file_num}.png not found\")\n",
        "    return train_image_map[file_num]\n",
        "\n",
        "def get_test_img_path_from_id(img_id):\n",
        "    file_num = int(img_id) + 1\n",
        "    if file_num not in test_image_map:\n",
        "        raise FileNotFoundError(f\"Test image img_{file_num}.png not found\")\n",
        "    return test_image_map[file_num]\n",
        "\n",
        "df[\"image_path\"] = df[\"id\"].apply(get_train_img_path_from_id)\n",
        "submission_example[\"image_path\"] = submission_example[\"id\"].apply(get_test_img_path_from_id)\n",
        "\n",
        "print(\"\\nVerified train paths:\", df[\"image_path\"].notnull().sum())\n",
        "print(\"Verified test paths:\", submission_example[\"image_path\"].notnull().sum())\n",
        "\n",
        "# =========================\n",
        "# 9. Show samples\n",
        "# =========================\n",
        "def show_samples(dataframe, n=8):\n",
        "    sample_df = dataframe.sample(min(n, len(dataframe)), random_state=42).reset_index(drop=True)\n",
        "    plt.figure(figsize=(16, 8))\n",
        "    for i in range(len(sample_df)):\n",
        "        img = Image.open(sample_df.loc[i, \"image_path\"]).convert(\"RGB\")\n",
        "        plt.subplot(2, math.ceil(len(sample_df) / 2), i + 1)\n",
        "        plt.imshow(img)\n",
        "        plt.title(f\"id={sample_df.loc[i, 'id']}, target={sample_df.loc[i, 'target']}\")\n",
        "        plt.axis(\"off\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "show_samples(df, n=8)\n",
        "\n",
        "# =========================\n",
        "# 10. Config\n",
        "# =========================\n",
        "CFG = {\n",
        "    \"img_size\": 256,\n",
        "    \"batch_size\": 32,\n",
        "    \"epochs\": 14,\n",
        "    \"lr\": 8e-4,\n",
        "    \"weight_decay\": 1e-4,\n",
        "    \"num_folds\": 5,\n",
        "    \"num_classes\": 4,\n",
        "    \"model_name\": \"efficientnet_b1\",\n",
        "    \"patience\": 5,\n",
        "    \"num_workers\": 2,\n",
        "    \"use_amp\": True,\n",
        "    \"label_smoothing\": 0.05,\n",
        "    \"focal_gamma\": 2.0,\n",
        "    \"tta\": False,  # leave False first; turn True later if needed\n",
        "}\n",
        "\n",
        "print(\"\\nConfig:\", CFG)\n",
        "\n",
        "# =========================\n",
        "# 11. Transforms\n",
        "# =========================\n",
        "train_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "    transforms.RandomRotation(degrees=8),\n",
        "    transforms.RandomAffine(\n",
        "        degrees=0,\n",
        "        translate=(0.04, 0.04),\n",
        "        scale=(0.97, 1.03)\n",
        "    ),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "valid_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "tta_transform = transforms.Compose([\n",
        "    transforms.Resize((CFG[\"img_size\"], CFG[\"img_size\"])),\n",
        "    transforms.RandomAffine(\n",
        "        degrees=0,\n",
        "        translate=(0.02, 0.02),\n",
        "        scale=(0.99, 1.01)\n",
        "    ),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(\n",
        "        mean=[0.485, 0.456, 0.406],\n",
        "        std=[0.229, 0.224, 0.225]\n",
        "    ),\n",
        "])\n",
        "\n",
        "# =========================\n",
        "# 12. Dataset\n",
        "# =========================\n",
        "class OccupancyDataset(Dataset):\n",
        "    def __init__(self, dataframe, transform=None, is_test=False):\n",
        "        self.dataframe = dataframe.reset_index(drop=True).copy()\n",
        "        self.transform = transform\n",
        "        self.is_test = is_test\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.dataframe)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        row = self.dataframe.iloc[idx]\n",
        "        img_path = row[\"image_path\"]\n",
        "\n",
        "        image = Image.open(img_path).convert(\"RGB\")\n",
        "\n",
        "        if self.transform is not None:\n",
        "            image = self.transform(image)\n",
        "\n",
        "        if self.is_test:\n",
        "            return image, int(row[\"id\"])\n",
        "\n",
        "        label = int(row[\"target\"])\n",
        "        return image, label\n",
        "\n",
        "# =========================\n",
        "# 13. Model\n",
        "# =========================\n",
        "class OccupancyModel(nn.Module):\n",
        "    def __init__(self, model_name=\"efficientnet_b1\", num_classes=4, pretrained=True):\n",
        "        super().__init__()\n",
        "        self.model = timm.create_model(\n",
        "            model_name,\n",
        "            pretrained=pretrained,\n",
        "            num_classes=num_classes\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        return self.model(x)\n",
        "\n",
        "# =========================\n",
        "# 14. Focal Loss with class weights\n",
        "# =========================\n",
        "class FocalLoss(nn.Module):\n",
        "    def __init__(self, alpha=None, gamma=2.0, smoothing=0.0):\n",
        "        super().__init__()\n",
        "        self.alpha = alpha\n",
        "        self.gamma = gamma\n",
        "        self.smoothing = smoothing\n",
        "\n",
        "    def forward(self, logits, targets):\n",
        "        num_classes = logits.size(1)\n",
        "\n",
        "        with torch.no_grad():\n",
        "            true_dist = torch.zeros_like(logits)\n",
        "            true_dist.fill_(self.smoothing / (num_classes - 1))\n",
        "            true_dist.scatter_(1, targets.data.unsqueeze(1), 1.0 - self.smoothing)\n",
        "\n",
        "        log_probs = F.log_softmax(logits, dim=1)\n",
        "        probs = torch.exp(log_probs)\n",
        "\n",
        "        ce_loss = -(true_dist * log_probs).sum(dim=1)\n",
        "        pt = (true_dist * probs).sum(dim=1)\n",
        "        focal_term = (1 - pt) ** self.gamma\n",
        "\n",
        "        loss = focal_term * ce_loss\n",
        "\n",
        "        if self.alpha is not None:\n",
        "            class_weights_sample = self.alpha[targets]\n",
        "            loss = loss * class_weights_sample\n",
        "\n",
        "        return loss.mean()\n",
        "\n",
        "# =========================\n",
        "# 15. Class weights\n",
        "# =========================\n",
        "class_counts = df[\"target\"].value_counts().sort_index().values.astype(np.float32)\n",
        "class_weights = 1.0 / class_counts\n",
        "class_weights = class_weights / class_weights.sum() * len(class_weights)\n",
        "class_weights = torch.tensor(class_weights, dtype=torch.float32).to(device)\n",
        "\n",
        "print(\"\\nClass counts:\", class_counts)\n",
        "print(\"Class weights:\", class_weights)\n",
        "\n",
        "# =========================\n",
        "# 16. Train / validation\n",
        "# =========================\n",
        "def train_one_epoch(model, loader, criterion, optimizer, scaler=None):\n",
        "    model.train()\n",
        "    running_loss = 0.0\n",
        "    preds_all = []\n",
        "    targets_all = []\n",
        "\n",
        "    for images, targets in loader:\n",
        "        images = images.to(device, non_blocking=True)\n",
        "        targets = targets.to(device, non_blocking=True)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "\n",
        "        if CFG[\"use_amp\"]:\n",
        "            with torch.cuda.amp.autocast():\n",
        "                outputs = model(images)\n",
        "                loss = criterion(outputs, targets)\n",
        "            scaler.scale(loss).backward()\n",
        "            scaler.step(optimizer)\n",
        "            scaler.update()\n",
        "        else:\n",
        "            outputs = model(images)\n",
        "            loss = criterion(outputs, targets)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "        running_loss += loss.item() * images.size(0)\n",
        "\n",
        "        preds = torch.argmax(outputs, dim=1)\n",
        "        preds_all.extend(preds.detach().cpu().numpy())\n",
        "        targets_all.extend(targets.detach().cpu().numpy())\n",
        "\n",
        "    epoch_loss = running_loss / len(loader.dataset)\n",
        "    epoch_acc = accuracy_score(targets_all, preds_all)\n",
        "    epoch_f1 = f1_score(targets_all, preds_all, average=\"macro\")\n",
        "\n",
        "    return epoch_loss, epoch_acc, epoch_f1\n",
        "\n",
        "def valid_one_epoch(model, loader, criterion):\n",
        "    model.eval()\n",
        "    running_loss = 0.0\n",
        "    preds_all = []\n",
        "    targets_all = []\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for images, targets in loader:\n",
        "            images = images.to(device, non_blocking=True)\n",
        "            targets = targets.to(device, non_blocking=True)\n",
        "\n",
        "            if CFG[\"use_amp\"]:\n",
        "                with torch.cuda.amp.autocast():\n",
        "                    outputs = model(images)\n",
        "                    loss = criterion(outputs, targets)\n",
        "            else:\n",
        "                outputs = model(images)\n",
        "                loss = criterion(outputs, targets)\n",
        "\n",
        "            running_loss += loss.item() * images.size(0)\n",
        "            preds = torch.argmax(outputs, dim=1)\n",
        "\n",
        "            preds_all.extend(preds.detach().cpu().numpy())\n",
        "            targets_all.extend(targets.detach().cpu().numpy())\n",
        "\n",
        "    epoch_loss = running_loss / len(loader.dataset)\n",
        "    epoch_acc = accuracy_score(targets_all, preds_all)\n",
        "    epoch_f1 = f1_score(targets_all, preds_all, average=\"macro\")\n",
        "    cm = confusion_matrix(targets_all, preds_all)\n",
        "\n",
        "    return epoch_loss, epoch_acc, epoch_f1, cm, targets_all, preds_all\n",
        "\n",
        "# =========================\n",
        "# 17. Cross-validation training\n",
        "# =========================\n",
        "skf = StratifiedKFold(n_splits=CFG[\"num_folds\"], shuffle=True, random_state=42)\n",
        "\n",
        "fold_scores = []\n",
        "best_model_paths = []\n",
        "\n",
        "for fold, (train_idx, valid_idx) in enumerate(skf.split(df, df[\"target\"])):\n",
        "    print(\"\\n\" + \"=\" * 70)\n",
        "    print(f\"FOLD {fold + 1}/{CFG['num_folds']}\")\n",
        "    print(\"=\" * 70)\n",
        "\n",
        "    train_df = df.iloc[train_idx].reset_index(drop=True)\n",
        "    valid_df = df.iloc[valid_idx].reset_index(drop=True)\n",
        "\n",
        "    train_dataset = OccupancyDataset(train_df, transform=train_transform, is_test=False)\n",
        "    valid_dataset = OccupancyDataset(valid_df, transform=valid_transform, is_test=False)\n",
        "\n",
        "    train_loader = DataLoader(\n",
        "        train_dataset,\n",
        "        batch_size=CFG[\"batch_size\"],\n",
        "        shuffle=True,\n",
        "        num_workers=CFG[\"num_workers\"],\n",
        "        pin_memory=True\n",
        "    )\n",
        "\n",
        "    valid_loader = DataLoader(\n",
        "        valid_dataset,\n",
        "        batch_size=CFG[\"batch_size\"],\n",
        "        shuffle=False,\n",
        "        num_workers=CFG[\"num_workers\"],\n",
        "        pin_memory=True\n",
        "    )\n",
        "\n",
        "    model = OccupancyModel(\n",
        "        model_name=CFG[\"model_name\"],\n",
        "        num_classes=CFG[\"num_classes\"],\n",
        "        pretrained=True\n",
        "    ).to(device)\n",
        "\n",
        "    criterion = FocalLoss(\n",
        "        alpha=class_weights,\n",
        "        gamma=CFG[\"focal_gamma\"],\n",
        "        smoothing=CFG[\"label_smoothing\"]\n",
        "    )\n",
        "\n",
        "    optimizer = optim.AdamW(\n",
        "        model.parameters(),\n",
        "        lr=CFG[\"lr\"],\n",
        "        weight_decay=CFG[\"weight_decay\"]\n",
        "    )\n",
        "\n",
        "    scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
        "        optimizer,\n",
        "        T_max=CFG[\"epochs\"],\n",
        "        eta_min=1e-6\n",
        "    )\n",
        "\n",
        "    scaler = torch.cuda.amp.GradScaler(enabled=CFG[\"use_amp\"])\n",
        "\n",
        "    best_f1 = -1.0\n",
        "    patience_counter = 0\n",
        "    best_cm = None\n",
        "    best_report = None\n",
        "    best_model_path = os.path.join(MODEL_DIR, f\"best_model_fold_{fold}.pth\")\n",
        "\n",
        "    for epoch in range(CFG[\"epochs\"]):\n",
        "        start_time = time.time()\n",
        "\n",
        "        train_loss, train_acc, train_f1 = train_one_epoch(\n",
        "            model, train_loader, criterion, optimizer, scaler\n",
        "        )\n",
        "        valid_loss, valid_acc, valid_f1, cm, y_true, y_pred = valid_one_epoch(\n",
        "            model, valid_loader, criterion\n",
        "        )\n",
        "\n",
        "        scheduler.step()\n",
        "        epoch_time = time.time() - start_time\n",
        "\n",
        "        print(\n",
        "            f\"Epoch {epoch+1:02d}/{CFG['epochs']} | \"\n",
        "            f\"train_loss={train_loss:.4f} train_acc={train_acc:.4f} train_f1={train_f1:.4f} | \"\n",
        "            f\"valid_loss={valid_loss:.4f} valid_acc={valid_acc:.4f} valid_f1={valid_f1:.4f} | \"\n",
        "            f\"time={epoch_time:.1f}s\"\n",
        "        )\n",
        "\n",
        "        if valid_f1 > best_f1:\n",
        "            best_f1 = valid_f1\n",
        "            patience_counter = 0\n",
        "            best_cm = cm\n",
        "            best_report = classification_report(y_true, y_pred, digits=4)\n",
        "            torch.save(model.state_dict(), best_model_path)\n",
        "            print(f\"Saved best model to: {best_model_path}\")\n",
        "        else:\n",
        "            patience_counter += 1\n",
        "\n",
        "        if patience_counter >= CFG[\"patience\"]:\n",
        "            print(\"Early stopping triggered.\")\n",
        "            break\n",
        "\n",
        "    print(\"\\nBest macro F1 for fold:\", round(best_f1, 6))\n",
        "    print(\"\\nBest confusion matrix:\")\n",
        "    print(best_cm)\n",
        "    print(\"\\nBest classification report:\")\n",
        "    print(best_report)\n",
        "\n",
        "    fold_scores.append(best_f1)\n",
        "    best_model_paths.append(best_model_path)\n",
        "\n",
        "    del model, train_loader, valid_loader, train_dataset, valid_dataset\n",
        "    gc.collect()\n",
        "    torch.cuda.empty_cache()\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"CV RESULTS\")\n",
        "print(\"=\" * 70)\n",
        "print(\"Fold macro F1 scores:\", [round(x, 6) for x in fold_scores])\n",
        "print(\"Mean CV macro F1:\", round(np.mean(fold_scores), 6))\n",
        "print(\"Std CV macro F1:\", round(np.std(fold_scores), 6))\n",
        "\n",
        "# =========================\n",
        "# 18. Test prediction with fold ensemble\n",
        "# =========================\n",
        "test_df = submission_example[[\"id\", \"image_path\"]].copy()\n",
        "test_dataset = OccupancyDataset(test_df, transform=valid_transform, is_test=True)\n",
        "test_loader = DataLoader(\n",
        "    test_dataset,\n",
        "    batch_size=CFG[\"batch_size\"],\n",
        "    shuffle=False,\n",
        "    num_workers=CFG[\"num_workers\"],\n",
        "    pin_memory=True\n",
        ")\n",
        "\n",
        "def predict_with_model(model, loader):\n",
        "    model.eval()\n",
        "    probs_all = []\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for images, _ in loader:\n",
        "            images = images.to(device, non_blocking=True)\n",
        "\n",
        "            if CFG[\"use_amp\"]:\n",
        "                with torch.cuda.amp.autocast():\n",
        "                    outputs = model(images)\n",
        "            else:\n",
        "                outputs = model(images)\n",
        "\n",
        "            probs = torch.softmax(outputs, dim=1)\n",
        "            probs_all.append(probs.cpu().numpy())\n",
        "\n",
        "    return np.concatenate(probs_all, axis=0)\n",
        "\n",
        "def predict_with_tta(model, dataframe, num_tta=3):\n",
        "    tta_probs = []\n",
        "\n",
        "    for t in range(num_tta):\n",
        "        print(f\"TTA round {t+1}/{num_tta}\")\n",
        "        tta_dataset = OccupancyDataset(dataframe, transform=tta_transform, is_test=True)\n",
        "        tta_loader = DataLoader(\n",
        "            tta_dataset,\n",
        "            batch_size=CFG[\"batch_size\"],\n",
        "            shuffle=False,\n",
        "            num_workers=CFG[\"num_workers\"],\n",
        "            pin_memory=True\n",
        "        )\n",
        "        probs = predict_with_model(model, tta_loader)\n",
        "        tta_probs.append(probs)\n",
        "\n",
        "        del tta_dataset, tta_loader\n",
        "        gc.collect()\n",
        "        torch.cuda.empty_cache()\n",
        "\n",
        "    return np.mean(tta_probs, axis=0)\n",
        "\n",
        "ensemble_probs = np.zeros((len(test_df), CFG[\"num_classes\"]), dtype=np.float32)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"ENSEMBLE PREDICTION\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "for fold, model_path in enumerate(best_model_paths):\n",
        "    print(f\"Loading fold {fold+1}: {model_path}\")\n",
        "\n",
        "    model = OccupancyModel(\n",
        "        model_name=CFG[\"model_name\"],\n",
        "        num_classes=CFG[\"num_classes\"],\n",
        "        pretrained=False\n",
        "    ).to(device)\n",
        "\n",
